---
// Fixed top navigation. `active` highlights the current page link.
interface Props { active?: 'home' | 'about' | 'skills' | 'projects' | 'contact'; }
const { active = 'home' } = Astro.props;

const links = [
  { key: 'home', label: 'Home', href: '/' },
  { key: 'about', label: 'About', href: '/about' },
  { key: 'skills', label: 'Skills', href: '/skills' },
  { key: 'projects', label: 'Projects', href: '/projects' },
  { key: 'contact', label: 'Contact', href: '/contact' },
];
---
<nav style="position:fixed; top:0; left:0; right:0; z-index:200; height:64px; display:flex; align-items:center; justify-content:center; background:rgba(14,18,17,0.85); backdrop-filter:blur(14px); -webkit-backdrop-filter:blur(14px); border-bottom:1px solid rgba(255,255,255,0.08); font-family:'Manrope',sans-serif;">
  <div style="width:100%; max-width:1240px; padding:0 clamp(18px,5vw,56px); display:flex; align-items:center; justify-content:space-between; box-sizing:border-box;">
    <a href="/" style="display:flex; align-items:center; gap:11px; text-decoration:none;">
      <svg width="30" height="30" viewBox="0 0 32 32" style="display:block;"><path d="M16 3 L27 11 L23 27 L9 27 L5 11 Z" fill="none" stroke="#4F7CFF" stroke-width="1.6" stroke-linejoin="round"></path><path d="M16 3 L16 27 M5 11 L27 11 M16 3 L9 27 M16 3 L23 27" stroke="#4F7CFF" stroke-width="0.9" opacity="0.55"></path><path d="M16 3 L27 11 L16 14 Z" fill="#7C5CFF" opacity="0.9"></path></svg>
      <span style="font-family:'Sora',sans-serif; font-weight:800; font-size:18px; color:#ECF1FF; letter-spacing:-0.02em;">JLW<span style="font-weight:500; color:#94A1C4;"> Analytics</span></span>
    </a>
    <button class="jlw-burger" aria-label="Menu" style="background:none; border:1px solid rgba(255,255,255,0.14); border-radius:10px; width:42px; height:42px; cursor:pointer; align-items:center; justify-content:center; padding:0;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ECF1FF" stroke-width="2" stroke-linecap="round"><path d="M4 7h16"></path><path d="M4 12h16"></path><path d="M4 17h16"></path></svg>
    </button>
    <div class="jlw-navlinks" style="display:flex; align-items:center; gap:clamp(14px,2.4vw,32px);">
      {links.map((l) => (
        <a
          class="navlink"
          href={l.href}
          style={`position:relative; text-decoration:none; color:${active === l.key ? '#ECF1FF' : '#94A1C4'}; font-size:15px; font-weight:${active === l.key ? '700' : '500'}; padding:4px 0;`}
        >
          {l.label}
          {active === l.key && (
            <span style="position:absolute; left:0; bottom:-2px; width:18px; height:2px; background:#4F7CFF; border-radius:2px;"></span>
          )}
        </a>
      ))}
      <a class="navlink" href="/company" style="display:inline-flex; align-items:center; gap:5px; text-decoration:none; color:#22D3EE; font-size:15px; font-weight:600; padding:4px 0;">
        JLW Analytics
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"></path><path d="M8 7h9v9"></path></svg>
      </a>
      <a class="cvbtn" href="/cv.pdf" download style="display:inline-flex; align-items:center; gap:8px; text-decoration:none; border:1.5px solid #4F7CFF; color:#4F7CFF; font-size:14px; font-weight:600; padding:9px 18px; border-radius:40px; transition:background .25s, color .25s;">
        Download CV
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"></path><path d="M7 11l5 4 5-4"></path><path d="M5 21h14"></path></svg>
      </a>
    </div>
  </div>
</nav>
<script>
  // Mobile hamburger toggle; close on link tap.
  const burger = document.querySelector('.jlw-burger');
  const links = document.querySelector('.jlw-navlinks');
  if (burger && links) {
    burger.addEventListener('click', () => links.classList.toggle('open'));
    links.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => links.classList.remove('open')));
  }
</script>
