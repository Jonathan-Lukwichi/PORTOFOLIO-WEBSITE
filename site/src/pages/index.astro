---
import BaseLayout from '../layouts/BaseLayout.astro';

const sectors = ['Healthcare', 'Mining', 'Manufacturing', 'Water', 'Ports', 'Supply Chain', 'Retail', 'Banking', 'Fleet', 'Construction', 'Warehousing'];
---
<BaseLayout title="Jonathan Lukwichi — JLW Analytics" active="home" hasRail={true}>
  <!-- LEFT SOCIAL RAIL (desktop ≥1081px) -->
  <div class="jlw-rail" slot="rail">
    <a href="https://linkedin.com/in/jonathan-lukwichi-24691b24b" target="_blank" rel="noopener" aria-label="LinkedIn"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"></path></svg></a>
    <a href="https://github.com/Jonathan-Lukwichi" target="_blank" rel="noopener" aria-label="GitHub"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.26.8-.58v-2.03c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.08-.74.09-.73.09-.73 1.2.09 1.83 1.24 1.83 1.24 1.07 1.83 2.81 1.3 3.5 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.69.82.57A12 12 0 0 0 12 .3z"></path></svg></a>
    <a href="mailto:jonathanlukwichi29@gmail.com" aria-label="Email"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="14" rx="2.5"></rect><path d="M3.5 7l8.5 6 8.5-6"></path></svg></a>
    <span style="width:1px; height:56px; background:rgba(255,255,255,0.14);"></span>
    <span style="font-family:'Space Mono',monospace; font-size:10px; letter-spacing:0.28em; color:#5F6B8E; writing-mode:vertical-rl; text-transform:uppercase;">Scroll</span>
  </div>

  <!-- HERO -->
  <section style="position:relative; max-width:1240px; margin:0 auto; padding:clamp(32px,6vw,72px) clamp(20px,5vw,56px) clamp(40px,6vw,80px); display:flex; flex-wrap:wrap; align-items:center; gap:48px; box-sizing:border-box;">
    <div style="position:absolute; inset:0; overflow:hidden; pointer-events:none; z-index:0;">
      <div style="position:absolute; top:-40px; right:4%; width:380px; height:380px; border-radius:50%; background:radial-gradient(circle at 40% 40%, rgba(79,124,255,0.16), transparent 70%); filter:blur(20px); animation:blobA 14s ease-in-out infinite;"></div>
      <div style="position:absolute; top:160px; right:30%; width:240px; height:240px; border-radius:50%; background:radial-gradient(circle at 50% 50%, rgba(79,124,255,0.08), transparent 70%); filter:blur(22px); animation:blobB 17s ease-in-out infinite;"></div>
    </div>

    <div style="flex:1 1 400px; min-width:260px; position:relative; z-index:1;">
      <div data-reveal style="opacity:1; transform:translateY(18px); transition:transform .7s cubic-bezier(.2,.7,.2,1); font-family:'Space Mono',monospace; font-size:13px; letter-spacing:0.18em; text-transform:uppercase; color:#4F7CFF; margin-bottom:18px;">&lt;/&gt; Hello, I'm</div>
      <h1 data-split data-reveal style="opacity:1; transform:translateY(18px); transition:transform .7s cubic-bezier(.2,.7,.2,1); font-family:'Cormorant Garamond',serif; font-weight:700; font-size:clamp(54px,7.6vw,104px); line-height:0.97; letter-spacing:-0.01em; margin:0 0 18px; color:#ECF1FF;">Jonathan<br>Lukwichi</h1>
      <p data-reveal style="opacity:1; transform:translateY(18px); transition:transform .7s cubic-bezier(.2,.7,.2,1); font-size:clamp(17px,2.1vw,23px); font-weight:600; margin:0 0 20px; color:#ECF1FF;">Simulation &amp; Digital-Twin Engineer <span style="font-family:'Cormorant Garamond',serif; font-style:italic; font-weight:600; font-size:1.25em; color:#7C5CFF;">· Founder of JLW Analytics</span></p>
      <p data-reveal style="opacity:1; transform:translateY(18px); transition:transform .7s cubic-bezier(.2,.7,.2,1); font-size:17px; line-height:1.75; color:#94A1C4; max-width:520px; margin:0 0 30px;">I build decision twins: simulation and machine learning that answer the <em style="color:#ECF1FF; font-style:normal; font-weight:600;">what-if</em>, <em style="color:#ECF1FF; font-style:normal; font-weight:600;">how-many</em> and <em style="color:#ECF1FF; font-style:normal; font-weight:600;">what-is-best</em> questions, before the money is spent.</p>
      <div data-reveal class="jlw-herosoc" style="opacity:1; transform:translateY(18px); transition:transform .7s cubic-bezier(.2,.7,.2,1); display:flex; gap:14px; margin-bottom:30px;">
        <a class="soc" href="https://linkedin.com/in/jonathan-lukwichi-24691b24b" target="_blank" rel="noopener" aria-label="LinkedIn" style="width:46px; height:46px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:#111A33; border:1px solid rgba(255,255,255,0.1); color:#ECF1FF; transition:background .25s, color .25s, transform .25s;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"></path></svg>
        </a>
        <a class="soc" href="https://github.com/Jonathan-Lukwichi" target="_blank" rel="noopener" aria-label="GitHub" style="width:46px; height:46px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:#111A33; border:1px solid rgba(255,255,255,0.1); color:#ECF1FF; transition:background .25s, color .25s, transform .25s;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.26.8-.58v-2.03c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.08-.74.09-.73.09-.73 1.2.09 1.83 1.24 1.83 1.24 1.07 1.83 2.81 1.3 3.5 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.69.82.57A12 12 0 0 0 12 .3z"></path></svg>
        </a>
        <a class="soc" href="mailto:jonathanlukwichi29@gmail.com" aria-label="Email" style="width:46px; height:46px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:#111A33; border:1px solid rgba(255,255,255,0.1); color:#ECF1FF; transition:background .25s, color .25s, transform .25s;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="14" rx="2.5"></rect><path d="M3.5 7l8.5 6 8.5-6"></path></svg>
        </a>
      </div>
      <div data-reveal style="opacity:1; transform:translateY(18px); transition:transform .7s cubic-bezier(.2,.7,.2,1); display:flex; flex-wrap:wrap; gap:14px;">
        <a class="btn-primary" href="/projects" style="display:inline-flex; align-items:center; gap:10px; text-decoration:none; background:#4F7CFF; color:#FFFFFF; font-weight:700; font-size:16px; padding:15px 28px; border-radius:44px; box-shadow:0 14px 34px rgba(79,124,255,0.28); transition:transform .25s, box-shadow .25s;">
          View the projects
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg>
        </a>
        <a class="btn-outline" href="/contact" style="display:inline-flex; align-items:center; text-decoration:none; background:transparent; color:#ECF1FF; font-weight:600; font-size:16px; padding:15px 26px; border-radius:44px; border:1.5px solid rgba(255,255,255,0.18); transition:border-color .25s, color .25s;">Let's talk</a>
      </div>
    </div>

    <div style="flex:1 1 320px; min-width:260px; position:relative; z-index:1; display:flex; justify-content:center;">
      <div class="fx-hud" style="position:relative; width:min(420px,86vw);">
        <div style="position:absolute; inset:-26px -18px -18px -26px; border-radius:40% 60% 58% 42% / 48% 42% 58% 52%; background:radial-gradient(circle at 50% 40%, rgba(34,211,238,0.32), rgba(124,92,255,0.10) 62%, transparent); filter:blur(8px); animation:blobA 12s ease-in-out infinite;"></div>
        <span class="fx-corner tl"></span><span class="fx-corner tr"></span><span class="fx-corner bl"></span><span class="fx-corner br"></span>
        <div data-reveal style="opacity:1; transform:translateY(18px); transition:transform .8s cubic-bezier(.2,.7,.2,1); position:relative; border-radius:30px 30px 30px 60px; overflow:hidden; aspect-ratio:3/4; box-shadow:0 30px 70px rgba(0,0,0,0.5), 0 0 50px rgba(34,211,238,0.18); border:1px solid rgba(34,211,238,0.4);">
          <div class="fx-scan"></div>
          <img src="/assets/home.png" alt="Jonathan Lukwichi" width="420" height="560" style="width:100%; height:100%; object-fit:cover; object-position:50% 8%; display:block;" />
        </div>
        <div data-reveal style="opacity:1; transform:translateY(12px); transition:transform .6s ease; position:absolute; top:22px; left:-22px; background:rgba(20,25,23,0.92); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.1); border-radius:14px; padding:11px 16px; box-shadow:0 12px 28px rgba(0,0,0,0.4); display:flex; align-items:center; gap:9px;">
          <span style="width:9px; height:9px; border-radius:50%; background:#4F7CFF; display:inline-block;"></span>
          <span style="font-size:13.5px; font-weight:600; color:#ECF1FF;">Open to pilots &amp; relocation</span>
        </div>
        <div data-reveal style="opacity:1; transform:translateY(12px); transition:transform .6s ease; position:absolute; bottom:18px; right:-18px; background:#4F7CFF; color:#FFFFFF; border-radius:16px; padding:14px 18px; box-shadow:0 16px 34px rgba(79,124,255,0.35);">
          <div style="font-family:'Sora',sans-serif; font-weight:800; font-size:26px; line-height:1;">15</div>
          <div style="font-size:12.5px; font-weight:600; margin-top:3px;">delivered case studies</div>
        </div>
      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <div style="border-top:1px solid rgba(255,255,255,0.07); border-bottom:1px solid rgba(255,255,255,0.07); padding:18px 0; overflow:hidden; background:rgba(255,255,255,0.02);">
    <div style="display:flex; width:max-content; animation:marquee 32s linear infinite; font-family:'Space Mono',monospace; font-size:14px; letter-spacing:0.12em; text-transform:uppercase; color:#94A1C4;">
      <span style="display:flex; gap:34px; padding-right:34px;">{sectors.map((s) => (<><span set:html={s}></span><span style="color:#4F7CFF;">◆</span></>))}</span>
      <span style="display:flex; gap:34px; padding-right:34px;" aria-hidden="true">{sectors.map((s) => (<><span set:html={s}></span><span style="color:#4F7CFF;">◆</span></>))}</span>
    </div>
  </div>

  <!-- DECISION TWIN -->
  <section data-reveal style="max-width:1240px; margin:0 auto; padding:clamp(56px,8vw,104px) clamp(20px,5vw,56px); opacity:1; transform:translateY(26px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <div style="font-family:'Space Mono',monospace; font-size:13px; letter-spacing:0.18em; text-transform:uppercase; color:#4F7CFF; margin-bottom:14px;">// The method</div>
    <h2 style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(28px,4.2vw,52px); line-height:1.08; letter-spacing:-0.025em; margin:0 0 18px; max-width:760px; color:#ECF1FF;">Engineering decisions, not just dashboards.</h2>
    <p style="font-size:17.5px; line-height:1.7; color:#94A1C4; max-width:680px; margin:0 0 48px;">Most analytics reports what already happened. My work sits where it stops: I turn a real operation into a living model, put a learning layer inside it, and prove the value of a decision before a cent is committed.</p>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(min(260px,100%),1fr)); gap:18px;">
      <div class="mcard" style="background:#111A33; border:1px solid rgba(255,255,255,0.07); border-radius:22px; padding:30px 28px; transition:transform .3s, border-color .3s;">
        <div style="font-family:'Space Mono',monospace; font-weight:700; font-size:18px; color:#4F7CFF; margin-bottom:14px;">01</div>
        <h3 style="font-family:'Sora',sans-serif; font-weight:700; font-size:21px; margin:0 0 10px; color:#ECF1FF;">Make a living model</h3>
        <p style="font-size:15.5px; line-height:1.65; color:#94A1C4; margin:0;">Discrete-event, agent-based or system-dynamics simulation of the real process — with its surges, queues and breakdowns intact.</p>
      </div>
      <div class="mcard" style="background:#111A33; border:1px solid rgba(255,255,255,0.07); border-radius:22px; padding:30px 28px; transition:transform .3s, border-color .3s;">
        <div style="font-family:'Space Mono',monospace; font-weight:700; font-size:18px; color:#4F7CFF; margin-bottom:14px;">02</div>
        <h3 style="font-family:'Sora',sans-serif; font-weight:700; font-size:21px; margin:0 0 10px; color:#ECF1FF;">Put learning inside it</h3>
        <p style="font-size:15.5px; line-height:1.65; color:#94A1C4; margin:0;">A machine-learning layer — forecasting, classification, survival or optimisation — drives the policy the model runs under.</p>
      </div>
      <div class="mcard" style="background:#111A33; border:1px solid rgba(255,255,255,0.07); border-radius:22px; padding:30px 28px; transition:transform .3s, border-color .3s;">
        <div style="font-family:'Space Mono',monospace; font-weight:700; font-size:18px; color:#4F7CFF; margin-bottom:14px;">03</div>
        <h3 style="font-family:'Sora',sans-serif; font-weight:700; font-size:21px; margin:0 0 10px; color:#ECF1FF;">Prove the decision</h3>
        <p style="font-size:15.5px; line-height:1.65; color:#94A1C4; margin:0;">Run the operation under today's rules versus the learning-driven policy, and measure the money value of the change.</p>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section data-reveal style="background:#070C1A; border-top:1px solid rgba(255,255,255,0.06); border-bottom:1px solid rgba(255,255,255,0.06); opacity:1; transform:translateY(26px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <div style="max-width:1240px; margin:0 auto; padding:clamp(48px,6vw,76px) clamp(20px,5vw,56px); display:grid; grid-template-columns:repeat(auto-fit,minmax(min(160px,100%),1fr)); gap:36px;">
      <div>
        <div style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(42px,5vw,60px); line-height:1; color:#4F7CFF;"><span data-count="15">0</span></div>
        <div style="font-size:15px; color:#94A1C4; margin-top:8px;">Delivered case studies</div>
      </div>
      <div>
        <div style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(42px,5vw,60px); line-height:1; color:#ECF1FF;"><span data-count="12">0</span></div>
        <div style="font-size:15px; color:#94A1C4; margin-top:8px;">Industries served</div>
      </div>
      <div>
        <div style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(42px,5vw,60px); line-height:1; color:#ECF1FF;"><span data-count="200">0</span>+</div>
        <div style="font-size:15px; color:#94A1C4; margin-top:8px;">Engineering students mentored</div>
      </div>
      <div>
        <div style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(42px,5vw,60px); line-height:1; color:#ECF1FF;"><span data-count="3">0</span></div>
        <div style="font-size:15px; color:#94A1C4; margin-top:8px;">Engineering degrees, two continents</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section data-reveal style="max-width:1240px; margin:0 auto; padding:clamp(56px,8vw,104px) clamp(20px,5vw,56px); opacity:1; transform:translateY(26px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <div style="background:linear-gradient(120deg,#4F7CFF,#7C5CFF); border-radius:30px; padding:clamp(36px,6vw,72px); color:#FFFFFF; position:relative; overflow:hidden;">
      <div style="position:absolute; top:-80px; right:-40px; width:300px; height:300px; border-radius:50%; background:rgba(255,255,255,0.16); animation:blobB 16s ease-in-out infinite;"></div>
      <div style="position:relative; max-width:640px;">
        <h2 style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(28px,4.2vw,48px); line-height:1.08; letter-spacing:-0.025em; margin:0 0 16px;">Let's find your money answer.</h2>
        <p style="font-size:17.5px; line-height:1.6; margin:0 0 30px; color:rgba(255,255,255,0.82);">If you are about to spend on capacity, fleet, staffing or equipment, a decision twin lets you test the change on your own data first — with a small, fixed-scope pilot and a clear, numbers-backed recommendation.</p>
        <div style="display:flex; flex-wrap:wrap; gap:14px;">
          <a class="ctabtn" href="/contact" style="display:inline-flex; align-items:center; gap:10px; text-decoration:none; background:#0A1124; color:#ECF1FF; font-weight:700; font-size:16px; padding:15px 28px; border-radius:44px; transition:transform .25s;">Start a conversation
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg>
          </a>
          <a class="btn-ghost" href="/projects" style="display:inline-flex; align-items:center; text-decoration:none; background:rgba(255,255,255,0.1); color:#FFFFFF; font-weight:600; font-size:16px; padding:15px 26px; border-radius:44px; border:1.5px solid rgba(255,255,255,0.3); transition:background .25s;">See the work</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
