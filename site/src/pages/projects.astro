---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects, services, roadmap, filters } from '../data/projects';

const stack = [
  { tier: 'Layer 3 · Digital Twin', note: 'Live mirror, predictive maintenance, real-time what-if', bg: 'linear-gradient(90deg,rgba(79,124,255,0.2),rgba(79,124,255,0.04))', border: '#4F7CFF' },
  { tier: 'Layer 2 · Simulation', note: 'Test decisions safely before committing', bg: 'linear-gradient(90deg,rgba(79,124,255,0.15),rgba(79,124,255,0.03))', border: '#4F7CFF' },
  { tier: 'Layer 1 · AI / ML Optimisation', note: 'Forecast demand, optimise inventory and schedules', bg: 'linear-gradient(90deg,rgba(79,124,255,0.1),rgba(79,124,255,0.02))', border: '#4F7CFF' },
  { tier: 'Data Layer', note: 'Import the spreadsheet or ERP, clean it into a real database', bg: 'rgba(255,255,255,0.04)', border: '#46527E' },
];
---
<BaseLayout title="Projects — Jonathan Lukwichi | JLW Analytics" active="projects">
  <!-- HEADER -->
  <section data-reveal style="max-width:1240px; margin:0 auto; padding:clamp(40px,6vw,80px) clamp(20px,5vw,56px) clamp(20px,3vw,32px); opacity:1; transform:translateY(20px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <div style="font-family:'Space Mono',monospace; font-size:13px; letter-spacing:0.18em; text-transform:uppercase; color:#4F7CFF; margin-bottom:16px;">&lt;/&gt; Selected work</div>
    <h1 data-split style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(32px,5vw,62px); line-height:1.05; letter-spacing:-0.03em; margin:0 0 18px; max-width:840px; color:#ECF1FF;">Fifteen delivered case studies — and the platform we're building now.</h1>
    <p style="font-size:17.5px; line-height:1.7; color:#94A1C4; max-width:720px; margin:0;">Each project pairs a working simulation engine with a machine-learning layer whose value is measured against a no-learning baseline. The results below are delivered outcomes, calibrated on realistic operational data.</p>
  </section>

  <!-- FLAGSHIP: BUILDING NOW -->
  <section data-reveal style="max-width:1240px; margin:0 auto; padding:clamp(16px,3vw,32px) clamp(20px,5vw,56px) clamp(32px,5vw,56px); opacity:1; transform:translateY(26px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <div style="background:#070C1A; border:1px solid rgba(79,124,255,0.2); color:#C4CDE8; border-radius:30px; padding:clamp(28px,4.5vw,60px); position:relative; overflow:hidden;">
      <div style="position:absolute; top:-90px; right:-50px; width:340px; height:340px; border-radius:50%; background:radial-gradient(circle at 40% 40%, rgba(79,124,255,0.22), transparent 70%); animation:blobB 18s ease-in-out infinite;"></div>
      <div style="position:relative;">
        <div style="display:inline-flex; align-items:center; gap:9px; background:rgba(79,124,255,0.12); border:1px solid rgba(79,124,255,0.4); color:#4F7CFF; font-family:'Space Mono',monospace; font-size:12px; letter-spacing:0.12em; text-transform:uppercase; padding:8px 14px; border-radius:30px; margin-bottom:20px;">
          <span style="width:8px; height:8px; border-radius:50%; background:#4F7CFF; display:inline-block; animation:livedot 2.4s ease-in-out infinite;"></span>
          Currently building · In progress
        </div>
        <h2 style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(26px,4vw,48px); line-height:1.08; letter-spacing:-0.025em; margin:0 0 16px; color:#ECF1FF; max-width:760px;">The Intelligent Operations Platform</h2>
        <p style="font-size:17.5px; line-height:1.7; color:#C4CDE8; max-width:720px; margin:0 0 12px;">Most production planning, inventory and scheduling still lives in fragile spreadsheets — manual, error-prone, impossible to optimise or test safely. We're building the layer that replaces it: <span style="color:#ECF1FF; font-weight:600;">forecast, optimise, simulate and run a live twin — all on the same data.</span></p>
        <p style="font-size:16px; line-height:1.7; color:#94A1C4; max-width:720px; margin:0 0 36px;">The wedge is a services-first, product-led model: land clients with high-ROI pilots, prove <em style="font-style:normal; color:#4F7CFF; font-weight:600;">independently measured savings</em>, then convert to a recurring platform. Consulting funds the build; the product scales the consulting.</p>

        <div style="display:flex; flex-wrap:wrap; gap:36px;">
          <!-- STACK -->
          <div style="flex:1 1 320px; min-width:260px;">
            <div style="font-family:'Space Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:#5F6B8E; margin-bottom:14px;">The stack</div>
            <div style="display:flex; flex-direction:column; gap:8px;">
              {stack.map((s) => (
                <div style={`background:${s.bg}; border-left:3px solid ${s.border}; border-radius:8px; padding:14px 16px;`}>
                  <div style="font-family:'Sora',sans-serif; font-weight:700; font-size:15px; color:#ECF1FF;">{s.tier}</div>
                  <div style="font-size:13px; color:#94A1C4; margin-top:2px;">{s.note}</div>
                </div>
              ))}
            </div>
          </div>
          <!-- SERVICE LINES -->
          <div style="flex:1 1 320px; min-width:260px;">
            <div style="font-family:'Space Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:#5F6B8E; margin-bottom:14px;">Independently sellable modules</div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
              {services.map((sv) => (
                <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:10px; padding:13px 14px;">
                  <div style="font-family:'Sora',sans-serif; font-weight:700; font-size:14px; color:#ECF1FF; line-height:1.25;">{sv.name}</div>
                  <div style="font-size:12.5px; color:#94A1C4; margin-top:4px; line-height:1.4;">{sv.outcome}</div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- ROADMAP -->
        <div style="margin-top:40px; padding-top:30px; border-top:1px solid rgba(255,255,255,0.1);">
          <div style="font-family:'Space Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:#5F6B8E; margin-bottom:16px;">Built in stages, one proven module at a time</div>
          <div style="display:flex; flex-wrap:wrap; gap:10px;">
            {roadmap.map((rm) => (
              <div style="display:flex; align-items:center; gap:10px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); border-radius:30px; padding:9px 16px 9px 10px;">
                <span style="width:24px; height:24px; border-radius:50%; background:#4F7CFF; color:#FFFFFF; font-family:'Sora',sans-serif; font-weight:700; font-size:12px; display:flex; align-items:center; justify-content:center; flex:0 0 auto;">{rm.n}</span>
                <span style="font-size:13.5px; font-weight:600; color:#C4CDE8;">{rm.label}</span>
              </div>
            ))}
          </div>
          <p style="font-size:14.5px; color:#5F6B8E; margin:18px 0 0; max-width:680px;">Grounded in adversarially fact-checked market research. The differentiator the market lacks: we measure and prove real outcomes rather than claiming them.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- DELIVERED HEADER + FILTER -->
  <section data-reveal style="max-width:1240px; margin:0 auto; padding:clamp(24px,4vw,40px) clamp(20px,5vw,56px) clamp(12px,2vw,20px); opacity:1; transform:translateY(22px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <h2 style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(26px,3.6vw,42px); line-height:1.1; letter-spacing:-0.025em; margin:0 0 22px; color:#ECF1FF;">Delivered case studies</h2>
    <div id="filterbar" style="display:flex; flex-wrap:wrap; gap:10px;">
      {filters.map((f, i) => (
        <button
          data-filter={f.key}
          style={`cursor:pointer; font-family:'Manrope',sans-serif; font-size:14px; font-weight:600; padding:9px 17px; border-radius:30px; transition:all .2s; ${i === 0 ? 'border:1px solid #4F7CFF; background:#4F7CFF; color:#FFFFFF;' : 'border:1px solid rgba(255,255,255,0.12); background:#111A33; color:#B4BEDC;'}`}
          set:html={f.label}
        ></button>
      ))}
    </div>
  </section>

  <!-- PROJECT GRID -->
  <section style="max-width:1240px; margin:0 auto; padding:clamp(16px,2vw,24px) clamp(20px,5vw,56px) clamp(48px,7vw,88px);">
    <div id="grid" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(min(340px,100%),1fr)); gap:18px;">
      {projects.map((p) => (
        <div class="pcard" data-reveal data-group={p.group} style="opacity:1; transform:translateY(24px); transition:transform .7s cubic-bezier(.2,.7,.2,1), border-color .3s; background:#111A33; border:1px solid rgba(255,255,255,0.07); border-radius:22px; padding:28px 26px; display:flex; flex-direction:column;">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
            <span style="font-family:'Sora',sans-serif; font-weight:800; font-size:28px; color:#4F7CFF; line-height:1;">{p.n}</span>
            <span style="font-family:'Space Mono',monospace; font-size:10.5px; letter-spacing:0.1em; text-transform:uppercase; color:#5F6B8E; text-align:right; max-width:160px;">{p.sector}</span>
          </div>
          <h3 style="font-family:'Sora',sans-serif; font-weight:700; font-size:20px; line-height:1.25; margin:0 0 14px; color:#ECF1FF;">{p.title}</h3>
          <div style="background:rgba(79,124,255,0.1); border:1px solid rgba(79,124,255,0.18); border-radius:12px; padding:12px 14px; margin-bottom:18px;">
            <div style="font-family:'Space Mono',monospace; font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:#4F7CFF; margin-bottom:4px;">Result</div>
            <div style="font-size:15px; font-weight:600; line-height:1.4; color:#ECF1FF;">{p.metric}</div>
          </div>
          <div style="margin-bottom:13px;">
            <div style="font-family:'Space Mono',monospace; font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:#5F6B8E; margin-bottom:4px;">Challenge</div>
            <p style="font-size:14px; line-height:1.55; color:#94A1C4; margin:0;">{p.challenge}</p>
          </div>
          <div style="margin-bottom:18px;">
            <div style="font-family:'Space Mono',monospace; font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:#5F6B8E; margin-bottom:4px;">Approach</div>
            <p style="font-size:14px; line-height:1.55; color:#94A1C4; margin:0;">{p.approach}</p>
          </div>
          <div style="margin-top:auto; display:flex; flex-wrap:wrap; gap:7px;">
            {p.tags.map((tag) => (
              <span style="font-family:'Space Mono',monospace; font-size:11px; background:rgba(255,255,255,0.06); color:#B4BEDC; padding:5px 10px; border-radius:20px;">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section data-reveal style="max-width:1240px; margin:0 auto; padding:0 clamp(20px,5vw,56px) clamp(56px,8vw,104px); opacity:1; transform:translateY(26px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <div style="background:linear-gradient(120deg,#4F7CFF,#7C5CFF); border-radius:28px; padding:clamp(34px,5vw,60px); color:#FFFFFF; text-align:center;">
      <h2 style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(26px,3.6vw,42px); line-height:1.1; letter-spacing:-0.025em; margin:0 auto 14px; max-width:620px;">Your operation could be the next case study.</h2>
      <p style="font-size:17px; line-height:1.6; margin:0 auto 28px; max-width:560px; color:rgba(255,255,255,0.82);">A small, fixed-scope pilot on your own data — with a clear recommendation and the numbers behind it.</p>
      <a class="ctabtn" href="/contact" style="display:inline-flex; align-items:center; gap:10px; text-decoration:none; background:#0A1124; color:#ECF1FF; font-weight:700; font-size:16px; padding:15px 30px; border-radius:44px; transition:transform .25s;">Start a pilot
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg>
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  // Sector filter for the delivered case studies.
  const btns = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter]'));
  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-group]'));
  btns.forEach((b) => {
    b.addEventListener('click', () => {
      const f = b.getAttribute('data-filter');
      btns.forEach((x) => {
        const on = x === b;
        x.style.background = on ? '#4F7CFF' : '#111A33';
        x.style.color = on ? '#FFFFFF' : '#B4BEDC';
        x.style.borderColor = on ? '#4F7CFF' : 'rgba(255,255,255,0.12)';
      });
      cards.forEach((c) => {
        const show = f === 'all' || c.getAttribute('data-group') === f;
        c.style.display = show ? 'flex' : 'none';
        if (show) { c.style.transform = 'none'; c.style.opacity = '1'; }
      });
    });
  });
</script>
