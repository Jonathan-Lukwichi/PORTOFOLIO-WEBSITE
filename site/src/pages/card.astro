---
// Print-ready business card (standalone — no site nav/cursor).
// View at /card → click "Print / Save as PDF". Cards are true size (85×55 mm).
// QR codes come from public/assets/qr-*.svg (regenerate via `npm run gen:qr`).
const email = 'jonathanlukwichi29@gmail.com';
const phone = '+27 84 731 4600';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Business Card — Jonathan Lukwichi · JLW Analytics</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { background: #14161c; font-family: 'Sora', sans-serif; }

    /* ---------- screen staging ---------- */
    .stage { min-height: 100vh; display: flex; flex-direction: column; align-items: center; gap: 26px; padding: 40px 20px 70px; }
    .toolbar { text-align: center; color: #ECEEF6; }
    .toolbar h1 { font-size: 22px; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 8px; }
    .toolbar p { font-size: 14px; color: #A7AABB; max-width: 460px; line-height: 1.6; margin: 0 auto 18px; }
    .printbtn { display: inline-flex; align-items: center; gap: 9px; cursor: pointer; border: none;
      background: linear-gradient(120deg, #0891B2, #1E5AA8); color: #fff; font-family: 'Sora'; font-weight: 700;
      font-size: 15px; padding: 13px 26px; border-radius: 40px; box-shadow: 0 14px 34px rgba(8,145,178,0.4); }
    .printbtn:hover { transform: translateY(-2px); }
    .cards { display: flex; flex-wrap: wrap; gap: 30px; justify-content: center; }
    .label { color: #6B7080; font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; text-align: center; margin-bottom: 10px; }
    /* show cards larger on screen than true size for legibility */
    .screen-zoom { transform: scale(1.55); transform-origin: top center; }
    .screen-slot { width: 85mm; }

    /* ---------- the card ---------- */
    .card {
      width: 85mm; height: 55mm; border-radius: 3mm; overflow: hidden; position: relative;
      background: #060606; color: #ECEEF6; box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }
    .card .grid {
      position: absolute; inset: 0;
      background-image: linear-gradient(rgba(34,211,238,0.08) 0.2mm, transparent 0.2mm), linear-gradient(90deg, rgba(34,211,238,0.08) 0.2mm, transparent 0.2mm);
      background-size: 6mm 6mm;
      -webkit-mask-image: radial-gradient(ellipse 80% 80% at 80% 20%, #000, transparent 75%);
              mask-image: radial-gradient(ellipse 80% 80% at 80% 20%, #000, transparent 75%);
    }
    .card .glow { position: absolute; width: 40mm; height: 40mm; border-radius: 50%; filter: blur(8mm); }
    .accent-edge { position: absolute; top: 0; bottom: 0; left: 0; width: 2mm; background: linear-gradient(180deg, #22D3EE, #1E5AA8); }

    /* FRONT */
    .front .inner { position: relative; height: 100%; padding: 6mm 6mm 5.5mm 8mm; display: flex; flex-direction: column; }
    .brand { display: flex; align-items: center; gap: 2.4mm; }
    .brand .wm { font-weight: 800; font-size: 4mm; letter-spacing: -0.02em; color: #ECEEF6; }
    .brand .wm span { font-weight: 500; color: #A7AABB; }
    .tagcode { margin-left: auto; font-family: 'Space Mono', monospace; font-size: 2.1mm; letter-spacing: 0.1em; color: #22D3EE; }
    .name { margin-top: auto; font-weight: 800; font-size: 6.4mm; line-height: 1.02; letter-spacing: -0.03em; color: #fff; }
    .role { margin-top: 1.6mm; font-size: 2.7mm; font-weight: 600; color: #ECEEF6; }
    .founder { font-size: 2.5mm; color: #22D3EE; font-weight: 600; margin-top: 0.6mm; }
    .contact { margin-top: 3.4mm; padding-top: 3mm; border-top: 0.2mm solid rgba(255,255,255,0.12); display: flex; flex-direction: column; gap: 1.3mm; }
    .contact .row { display: flex; align-items: center; gap: 2mm; font-size: 2.4mm; color: #C4CDE8; }
    .contact .row svg { width: 2.8mm; height: 2.8mm; flex: 0 0 auto; }
    .contact .loc { font-family: 'Space Mono', monospace; font-size: 2mm; color: #6B7080; letter-spacing: 0.06em; }

    /* BACK */
    .back .inner { position: relative; height: 100%; padding: 5mm 6mm; display: flex; flex-direction: column; align-items: center; }
    .back .scan { font-family: 'Space Mono', monospace; font-size: 2.3mm; letter-spacing: 0.16em; text-transform: uppercase; color: #22D3EE; margin-bottom: 0.8mm; }
    .back .sub { font-size: 2.2mm; color: #A7AABB; margin-bottom: 3.4mm; text-align: center; }
    .qrs { display: flex; gap: 6mm; justify-content: center; }
    .qrcell { text-align: center; }
    .qrtile { width: 24mm; height: 24mm; background: #fff; border-radius: 2mm; padding: 1.6mm; box-shadow: 0 1mm 3mm rgba(0,0,0,0.4); }
    .qrtile img { width: 100%; height: 100%; display: block; }
    .qrcell .cap { margin-top: 1.8mm; font-weight: 700; font-size: 2.5mm; color: #ECEEF6; }
    .qrcell .url { font-family: 'Space Mono', monospace; font-size: 1.9mm; color: #6B7080; margin-top: 0.4mm; }
    .back .foot { margin-top: auto; display: flex; align-items: center; gap: 2mm; }
    .back .foot .wm { font-weight: 800; font-size: 3mm; color: #ECEEF6; letter-spacing: -0.02em; }
    .back .foot .wm span { font-weight: 500; color: #A7AABB; }

    /* ---------- print ---------- */
    @page { size: 85mm 55mm; margin: 0; }
    @media print {
      html, body { background: #fff; }
      .stage { padding: 0; gap: 0; }
      .toolbar, .label { display: none !important; }
      .screen-zoom { transform: none !important; }
      .screen-slot { width: auto; }
      .cards { display: block; gap: 0; }
      .card { box-shadow: none; border-radius: 0; page-break-after: always; break-after: page; }
    }
  </style>
</head>
<body>
  <div class="stage">
    <div class="toolbar">
      <h1>Business card — print ready</h1>
      <p>Two sides at true size (85 × 55 mm). Click below, then in the print dialog choose
         <strong>Save as PDF</strong> and set <strong>Margins: None</strong> &amp; <strong>Scale: 100%</strong>.
         Each side prints on its own page.</p>
      <button class="printbtn" onclick="window.print()">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V2h12v7"></path><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
        Print / Save as PDF
      </button>
    </div>

    <div class="cards">
      <!-- FRONT -->
      <div class="screen-slot">
        <div class="label">Front</div>
        <div class="screen-zoom">
          <div class="card front">
            <div class="grid"></div>
            <div class="glow" style="background:radial-gradient(circle,rgba(34,211,238,0.30),transparent 70%); top:-14mm; right:-10mm;"></div>
            <div class="accent-edge"></div>
            <div class="inner">
              <div class="brand">
                <svg width="7mm" height="7mm" viewBox="0 0 32 32"><defs><linearGradient id="lg1" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#22D3EE"/><stop offset="1" stop-color="#1E5AA8"/></linearGradient></defs><path d="M16 3 L27 11 L23 27 L9 27 L5 11 Z" fill="none" stroke="url(#lg1)" stroke-width="1.6" stroke-linejoin="round"/><path d="M16 3 L16 27 M5 11 L27 11 M16 3 L9 27 M16 3 L23 27" stroke="#0891B2" stroke-width="0.9" opacity="0.6"/><path d="M16 3 L27 11 L16 14 Z" fill="#22D3EE" opacity="0.9"/></svg>
                <div class="wm">JLW<span> Analytics</span></div>
                <div class="tagcode">&lt;/&gt;</div>
              </div>
              <div class="name">Jonathan<br>Lukwichi</div>
              <div class="role">Simulation &amp; Digital-Twin Engineer</div>
              <div class="founder">Founder · JLW Analytics</div>
              <div class="contact">
                <div class="row">
                  <svg viewBox="0 0 24 24" fill="none" stroke="#22D3EE" stroke-width="1.8"><rect x="3" y="5" width="18" height="14" rx="2.5"></rect><path d="M3.5 7l8.5 6 8.5-6"></path></svg>
                  {email}
                </div>
                <div class="row">
                  <svg viewBox="0 0 24 24" fill="none" stroke="#22D3EE" stroke-width="1.8"><path d="M5 4h4l2 5-3 2a12 12 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"></path></svg>
                  {phone}
                </div>
                <div class="loc">PRETORIA · SOUTH AFRICA · EN / FR</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- BACK -->
      <div class="screen-slot">
        <div class="label">Back</div>
        <div class="screen-zoom">
          <div class="card back">
            <div class="grid"></div>
            <div class="glow" style="background:radial-gradient(circle,rgba(124,92,255,0.22),transparent 70%); bottom:-14mm; left:-10mm;"></div>
            <div class="inner">
              <div class="scan">Scan to connect</div>
              <div class="sub">Decision twins for operations — proven before the spend.</div>
              <div class="qrs">
                <div class="qrcell">
                  <div class="qrtile"><img src="/assets/qr-portfolio.svg" alt="Portfolio QR code" /></div>
                  <div class="cap">Portfolio</div>
                  <div class="url">jlwanalytics.com</div>
                </div>
                <div class="qrcell">
                  <div class="qrtile"><img src="/assets/qr-company.svg" alt="Company website QR code" /></div>
                  <div class="cap">Company</div>
                  <div class="url">jlwanalytics.com/company</div>
                </div>
              </div>
              <div class="foot">
                <svg width="5mm" height="5mm" viewBox="0 0 32 32"><defs><linearGradient id="lg2" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#22D3EE"/><stop offset="1" stop-color="#1E5AA8"/></linearGradient></defs><path d="M16 3 L27 11 L23 27 L9 27 L5 11 Z" fill="none" stroke="url(#lg2)" stroke-width="1.6" stroke-linejoin="round"/><path d="M16 3 L27 11 L16 14 Z" fill="#22D3EE" opacity="0.9"/></svg>
                <div class="wm">JLW<span> Analytics</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
