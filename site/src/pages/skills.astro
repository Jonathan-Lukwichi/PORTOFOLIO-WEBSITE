---
import BaseLayout from '../layouts/BaseLayout.astro';

const chips = ['Artificial Intelligence & ML', 'Time-series Forecasting', 'Predictive Modelling', 'Discrete-event Simulation', 'Agent-based Modelling', 'System Dynamics', 'Optimisation & Metaheuristics', 'Supply-chain Analytics', 'Cloud ML Platforms', 'Prompt Engineering & LLMs', 'Data Visualisation', 'ETL & Data Pipelines', 'Six Sigma & Lean', 'Industrial Automation', 'CAD & Engineering Modelling', 'Electrical Systems'];

const skills = [
  { title: 'AI & Machine Learning', desc: 'Forecasting systems and end-to-end learning pipelines that turn data into decisions.' },
  { title: 'Time-series Forecasting & Demand Planning', desc: 'Predictive models that drive surge-ahead, data-driven policy instead of guesswork.' },
  { title: 'Multi-method Simulation', desc: 'Discrete-event, agent-based and system-dynamics models of real operations.' },
  { title: 'Data Science & Analysis', desc: 'Exploratory analysis, statistical modelling and evidence-based decision support.' },
  { title: 'Supply-chain Analytics & Optimisation', desc: 'Multi-echelon inventory, network design, dispatch and bullwhip control.' },
  { title: 'Process & Quality Engineering', desc: 'Six Sigma Green Belt, Lean, DMAIC and control-system fundamentals.' },
  { title: 'Industrial Automation & Control', desc: 'Microcontroller-driven process control and instrumentation from the plant floor.' },
  { title: 'CAD & Electrical Systems', desc: 'Engineering modelling plus electrical, electronic and electromechanical systems.' },
];

const experience = [
  { period: 'Feb 2025 – Dec 2025', role: 'Teaching Assistant — Data Analytics & Engineering', org: 'University of Pretoria · Dept. of Mechanical & Aeronautical Engineering', points: ['Delivered technical instruction to 200+ engineering students across graphical communication, professional communication and engineering-impact modules, using data analysis to monitor and improve learning outcomes.', 'Analysed student-performance trends with data-analysis tooling, enabling evidence-based adjustments to teaching methods and assessment design.', 'Contributed to academic research in AI-driven forecasting and predictive analytics within the MSc Industrial Engineering programme.'] },
  { period: 'Feb 2025 – May 2025', role: 'Customer Service Representative', org: 'ACT TODAY Call Centre', points: ['Managed high-volume client interactions in a fast-paced environment, sharpening communication, prioritisation and problem-solving directly transferable to client-facing analytics and consulting.'] },
  { period: 'Jan 2019 – Mar 2019', role: 'Engineering Intern — Electrical & Process Engineering', org: 'Gécamines (State Mining Company), Lubumbashi, DRC', points: ['Maintained and optimised electrical power-distribution systems, electronic equipment and mechanical machinery across large-scale industrial mining operations.', 'Programmed and configured microcontrollers for automated process control, contributing to measurable uptime improvement.', 'Designed data-driven safety-inspection strategies for operational reliability and full compliance with mining standards.'] },
  { period: 'Jul 2013 – Aug 2013', role: 'Instrumentation Intern', org: 'Ruashi Mining, Lubumbashi, DRC', points: ['Supported installation, calibration and commissioning of industrial instrumentation in mineral-processing facilities, ensuring measurement accuracy and reliability.', 'Conducted preventive maintenance and troubleshooting to minimise downtime across processing lines.'] },
];

const education = [
  { period: '2024 – Present', degree: 'MSc, Industrial Engineering (Candidate)', org: 'University of Pretoria', note: 'Thesis: optimising hospital supply-chain demand forecasting with machine learning — a case study of South African public hospitals.' },
  { period: '2022 – 2023', degree: 'BSc Honours, Applied Science in Industrial Systems', org: 'University of Pretoria', note: 'Supply-chain design, modelling & simulation, industrial analysis, manufacturing control & planning, operations research.' },
  { period: '2014 – 2019', degree: 'BEng Tech, Electromechanical Engineering', org: 'University of Lubumbashi, DRC', note: 'Electrical circuits, electronics, mechanical systems design, computer-aided design and simulation.' },
  { period: '2008 – 2014', degree: 'National Senior Certificate, Industrial Electronics', org: 'Salama Technical Institute, DRC', note: 'Foundation in industrial electronics and technical systems.' },
];

const certs = [
  { area: 'AI & Machine Learning', items: ['Cloud machine-learning (professional course, 2026)', 'Applied ML for data science', 'No-code & practical modern ML tools', 'Machine-learning applications'] },
  { area: 'Prompt Engineering & LLMs', items: ['Advanced prompt-engineering certification', 'Prompt-engineering certification — mastering AI assistants'] },
  { area: 'Supply Chain & Business Analytics', items: ['Certified AI Supply-Chain Analyst (CAISCA)', 'Strategic supply-chain trade-offs & optimisation with AI', 'Demand-Planning Professional — CSCMP', 'Spreadsheet data analysis for supply-chain forecasting'] },
  { area: 'Programming & Quality', items: ['Programming for Everybody — University of Michigan', 'Six Sigma Green Belt — DMAIC & quality management', 'Faculty Teaching Assistant Training — University of Pretoria'] },
];
---
<BaseLayout title="Skills & Experience — Jonathan Lukwichi | JLW Analytics" active="skills">
  <!-- HEADER -->
  <section style="max-width:1240px; margin:0 auto; padding:clamp(40px,6vw,80px) clamp(20px,5vw,56px) clamp(24px,3vw,40px); display:flex; flex-wrap:wrap; gap:clamp(36px,5vw,72px); align-items:center;">
    <div data-reveal style="flex:1 1 440px; min-width:260px; opacity:1; transform:translateY(20px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
      <div style="font-family:'Space Mono',monospace; font-size:13px; letter-spacing:0.18em; text-transform:uppercase; color:#4F7CFF; margin-bottom:16px;">&lt;/&gt; Skills &amp; experience</div>
      <h1 data-split style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(32px,5vw,60px); line-height:1.05; letter-spacing:-0.03em; margin:0 0 22px; color:#ECF1FF;">A rare stack: operations engineering, simulation &amp; applied machine learning.</h1>
      <p style="font-size:17.5px; line-height:1.75; color:#B4BEDC; margin:0 0 28px; max-width:560px;">An engineering foundation across electrical systems, industrial automation and supply-chain optimisation — paired with intelligent forecasting and end-to-end machine-learning pipelines, grounded for African and emerging-market operations.</p>
      <a class="btn-primary" href="/cv.pdf" download style="display:inline-flex; align-items:center; gap:10px; text-decoration:none; background:#4F7CFF; color:#FFFFFF; font-weight:700; font-size:16px; padding:14px 26px; border-radius:44px; box-shadow:0 14px 30px rgba(79,124,255,0.28); transition:transform .25s;">
        Download full CV
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"></path><path d="M7 11l5 4 5-4"></path><path d="M5 21h14"></path></svg>
      </a>
    </div>
    <div data-reveal style="flex:0 1 320px; min-width:240px; opacity:1; transform:translateY(20px); transition:transform .8s cubic-bezier(.2,.7,.2,1); display:flex; justify-content:center;">
      <div style="position:relative; width:min(300px,76vw);">
        <div style="position:absolute; inset:-18px -14px -12px -18px; border-radius:48% 52% 54% 46% / 52% 46% 54% 48%; background:radial-gradient(circle at 50% 40%, rgba(79,124,255,0.26), transparent 68%); filter:blur(6px); animation:blobA 14s ease-in-out infinite;"></div>
        <div style="position:relative; border-radius:24px 24px 24px 48px; overflow:hidden; aspect-ratio:4/5; box-shadow:0 24px 56px rgba(0,0,0,0.5); border:1px solid rgba(79,124,255,0.25);">
          <img src="/assets/jonathan-alt.png" alt="Jonathan Lukwichi" width="300" height="375" style="width:100%; height:100%; object-fit:cover; object-position:50% 22%; display:block;" />
        </div>
      </div>
    </div>
  </section>

  <!-- SKILL CHIPS -->
  <section data-reveal style="max-width:1240px; margin:0 auto; padding:clamp(20px,3vw,36px) clamp(20px,5vw,56px); opacity:1; transform:translateY(22px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <div style="display:flex; flex-wrap:wrap; gap:11px;">
      {chips.map((chip) => (
        <span style="font-family:'Space Mono',monospace; font-size:13px; background:#111A33; border:1px solid rgba(255,255,255,0.1); color:#B4BEDC; padding:9px 15px; border-radius:30px;">{chip}</span>
      ))}
    </div>
  </section>

  <!-- CAPABILITY CARDS -->
  <section data-reveal style="max-width:1240px; margin:0 auto; padding:clamp(36px,5vw,64px) clamp(20px,5vw,56px); opacity:1; transform:translateY(26px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(min(260px,100%),1fr)); gap:18px;">
      {skills.map((s) => (
        <div class="scard" style="background:#111A33; border:1px solid rgba(255,255,255,0.07); border-radius:18px; padding:24px; transition:transform .3s, border-color .3s;">
          <h3 style="font-family:'Sora',sans-serif; font-weight:700; font-size:17.5px; margin:0 0 8px; color:#ECF1FF; line-height:1.25;">{s.title}</h3>
          <p style="font-size:14.5px; line-height:1.55; color:#94A1C4; margin:0;">{s.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section data-reveal style="background:#070C1A; border-top:1px solid rgba(255,255,255,0.06); border-bottom:1px solid rgba(255,255,255,0.06); color:#C4CDE8; opacity:1; transform:translateY(26px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <div style="max-width:1100px; margin:0 auto; padding:clamp(48px,7vw,92px) clamp(20px,5vw,56px);">
      <div style="font-family:'Space Mono',monospace; font-size:13px; letter-spacing:0.18em; text-transform:uppercase; color:#4F7CFF; margin-bottom:14px;">// Experience</div>
      <h2 style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(26px,3.8vw,44px); line-height:1.1; letter-spacing:-0.025em; margin:0 0 48px; color:#ECF1FF;">From the mine floor to the research lab.</h2>
      <div style="display:flex; flex-direction:column; gap:0;">
        {experience.map((e) => (
          <div style="display:flex; gap:24px; padding-bottom:36px; position:relative;">
            <div style="flex:0 0 12px; display:flex; flex-direction:column; align-items:center;">
              <span style="width:12px; height:12px; border-radius:50%; background:#4F7CFF; margin-top:6px; flex:0 0 auto;"></span>
              <span style="width:2px; flex:1 1 auto; background:rgba(255,255,255,0.12); margin-top:6px;"></span>
            </div>
            <div style="flex:1 1 auto;">
              <div style="font-family:'Space Mono',monospace; font-size:12px; letter-spacing:0.08em; color:#5F6B8E; margin-bottom:6px;">{e.period}</div>
              <h3 style="font-family:'Sora',sans-serif; font-weight:700; font-size:20px; margin:0 0 3px; color:#ECF1FF;">{e.role}</h3>
              <div style="font-size:15px; color:#8FA8FF; margin-bottom:14px;">{e.org}</div>
              <ul style="margin:0; padding-left:18px; display:flex; flex-direction:column; gap:8px;">
                {e.points.map((pt) => (
                  <li style="font-size:15px; line-height:1.6; color:#94A1C4;">{pt}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EDUCATION + CERTS -->
  <section data-reveal style="max-width:1240px; margin:0 auto; padding:clamp(48px,7vw,92px) clamp(20px,5vw,56px); opacity:1; transform:translateY(26px); transition:transform .8s cubic-bezier(.2,.7,.2,1); display:flex; flex-wrap:wrap; gap:clamp(36px,5vw,64px);">
    <div style="flex:1 1 360px; min-width:260px;">
      <div style="font-family:'Space Mono',monospace; font-size:13px; letter-spacing:0.18em; text-transform:uppercase; color:#4F7CFF; margin-bottom:14px;">// Education</div>
      <h2 style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(24px,3.4vw,38px); line-height:1.12; letter-spacing:-0.02em; margin:0 0 30px; color:#ECF1FF;">Three degrees, two continents.</h2>
      <div style="display:flex; flex-direction:column; gap:18px;">
        {education.map((ed) => (
          <div style="background:#111A33; border:1px solid rgba(255,255,255,0.07); border-radius:18px; padding:22px 24px;">
            <div style="font-family:'Space Mono',monospace; font-size:12px; color:#5F6B8E; margin-bottom:6px;">{ed.period}</div>
            <h3 style="font-family:'Sora',sans-serif; font-weight:700; font-size:17.5px; margin:0 0 3px; line-height:1.25; color:#ECF1FF;">{ed.degree}</h3>
            <div style="font-size:14.5px; color:#8FA8FF; margin-bottom:6px;">{ed.org}</div>
            <p style="font-size:14px; line-height:1.55; color:#94A1C4; margin:0;">{ed.note}</p>
          </div>
        ))}
      </div>
    </div>
    <div style="flex:1 1 360px; min-width:260px;">
      <div style="font-family:'Space Mono',monospace; font-size:13px; letter-spacing:0.18em; text-transform:uppercase; color:#4F7CFF; margin-bottom:14px;">// Certifications &amp; training</div>
      <h2 style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(24px,3.4vw,38px); line-height:1.12; letter-spacing:-0.02em; margin:0 0 30px; color:#ECF1FF;">Always sharpening the stack.</h2>
      <div style="display:flex; flex-direction:column; gap:22px;">
        {certs.map((grp) => (
          <div>
            <h3 style="font-family:'Sora',sans-serif; font-weight:700; font-size:15.5px; margin:0 0 12px; color:#4F7CFF;">{grp.area}</h3>
            <div style="display:flex; flex-direction:column; gap:9px;">
              {grp.items.map((it) => (
                <div style="display:flex; gap:10px; align-items:flex-start;">
                  <span style="width:6px; height:6px; border-radius:50%; background:#4F7CFF; margin-top:8px; flex:0 0 auto;"></span>
                  <span style="font-size:15px; line-height:1.5; color:#B4BEDC;">{it}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
        <div style="border-top:1px solid rgba(255,255,255,0.1); padding-top:20px; margin-top:4px;">
          <h3 style="font-family:'Sora',sans-serif; font-weight:700; font-size:15.5px; margin:0 0 12px; color:#4F7CFF;">Languages</h3>
          <div style="display:flex; gap:24px; flex-wrap:wrap;">
            <div><span style="font-weight:700; font-size:16px; color:#ECF1FF;">English</span><span style="font-size:14px; color:#94A1C4;"> · Professional working</span></div>
            <div><span style="font-weight:700; font-size:16px; color:#ECF1FF;">French</span><span style="font-size:14px; color:#94A1C4;"> · Native / bilingual</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
