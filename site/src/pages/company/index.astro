---
import CompanyLayout from '../../layouts/CompanyLayout.astro';

const sectors = ['Mining', 'Manufacturing', 'Supply Chain', 'Healthcare', 'Water', 'Ports', 'Retail', 'Banking', 'Fleet', 'Construction', 'Warehousing'];

const services = [
  {
    name: 'Simulation & digital twins',
    desc: 'Discrete-event, agent-based and system-dynamics models that mirror your real operation — surges, queues and breakdowns intact — so you can test a change before touching the floor.',
    icon: '<path d="M12 2v4M12 18v4M2 12h4M18 12h4M5 5l2.5 2.5M16.5 16.5L19 19M19 5l-2.5 2.5M7.5 16.5L5 19"></path><circle cx="12" cy="12" r="3.5"></circle>',
  },
  {
    name: 'Forecasting & ML',
    desc: 'Demand forecasting, survival, classification and optimisation models — each measured against a no-learning baseline, so the value of the prediction is proven, not assumed.',
    icon: '<path d="M3 17l5-5 4 3 6-7"></path><path d="M16 8h4v4"></path><path d="M3 21h18"></path>',
  },
  {
    name: 'Supply-chain & operations',
    desc: 'Multi-echelon inventory, dispatch, network design and bullwhip control — find the configuration that minimises cost and lateness across the whole system, not one node.',
    icon: '<rect x="3" y="8" width="7" height="7" rx="1.2"></rect><rect x="14" y="4" width="7" height="7" rx="1.2"></rect><rect x="14" y="14" width="7" height="6" rx="1.2"></rect><path d="M10 11h4M17.5 11v3"></path>',
  },
  {
    name: 'Decision tooling & dashboards',
    desc: 'Data pipelines and decision-support apps that put the model in front of the people who decide — clean inputs in, a clear recommendation with the numbers behind it out.',
    icon: '<rect x="3" y="4" width="18" height="14" rx="2"></rect><path d="M3 9h18M8 13h3M14 13h2M8 18v3M16 18v3M6 21h12"></path>',
  },
];

const stats = [
  { n: 15, suffix: '', label: 'Delivered case studies' },
  { n: 12, suffix: '', label: 'Industries served' },
  { n: 4, suffix: '', label: 'Method families in one engine' },
  { n: 100, suffix: '%', label: 'Decisions measured vs a baseline' },
];

const process = [
  { n: '01', title: 'Discover', desc: 'We scope one high-value decision and pull your real data — spreadsheet, ERP or sensor feed — into a clean model.' },
  { n: '02', title: 'Model', desc: 'A living simulation of the operation, with a machine-learning layer driving the policy it runs under.' },
  { n: '03', title: 'Prove', desc: 'Run today’s rules versus the learning-driven policy and measure the money value of the change — before you commit.' },
  { n: '04', title: 'Deploy', desc: 'Ship the recommendation as a decision tool or live twin, and keep it calibrated as the operation evolves.' },
];

const testimonials = [
  { quote: 'They proved a fleet-maintenance change was worth seven figures a year before we spent a cent on it. That number held when we rolled it out.', who: 'Operations lead', sector: 'Mining client' },
  { quote: 'We had been guessing at inventory for years. The twin showed exactly where the carrying cost was hiding and what policy to run instead.', who: 'Supply-chain manager', sector: 'Manufacturing client' },
  { quote: 'The pilot was small, fixed-scope and paid for itself. We could finally test a what-if without risking the live operation.', who: 'Plant director', sector: 'Process industry client' },
];
---
<CompanyLayout title="JLW Analytics — Decision twins for operations" active="home">
  <!-- HERO -->
  <section style="position:relative; max-width:1240px; margin:0 auto; padding:clamp(40px,7vw,96px) clamp(20px,5vw,56px) clamp(32px,5vw,64px); display:flex; flex-wrap:wrap; align-items:center; gap:48px;">
    <div style="flex:1 1 440px; min-width:280px; position:relative; z-index:1;">
      <div data-reveal style="opacity:1; transform:translateY(18px); transition:transform .7s cubic-bezier(.2,.7,.2,1); display:inline-flex; align-items:center; gap:9px; background:rgba(8,145,178,0.1); border:1px solid rgba(34,211,238,0.3); color:#22D3EE; font-family:'Space Mono',monospace; font-size:12px; letter-spacing:0.12em; text-transform:uppercase; padding:8px 14px; border-radius:30px; margin-bottom:22px;">
        <span style="width:8px; height:8px; border-radius:50%; background:#22D3EE; display:inline-block; animation:livedot 2.4s ease-in-out infinite;"></span>
        Simulation · Machine learning · Digital twins
      </div>
      <h1 data-split style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(38px,5.6vw,68px); line-height:1.04; letter-spacing:-0.03em; margin:0 0 22px; color:#ECEEF6;">We turn operations into decisions you can <span style="background:linear-gradient(120deg,#22D3EE,#1E5AA8); -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent;">prove</span>.</h1>
      <p data-reveal style="opacity:1; transform:translateY(18px); transition:transform .7s cubic-bezier(.2,.7,.2,1); font-size:clamp(16px,2vw,19px); line-height:1.7; color:#A7AABB; max-width:540px; margin:0 0 32px;">JLW Analytics builds decision twins — a living model of your operation with a learning layer inside it. We answer the <span style="color:#ECEEF6; font-weight:600;">what-if</span>, <span style="color:#ECEEF6; font-weight:600;">how-many</span> and <span style="color:#ECEEF6; font-weight:600;">what-is-best</span> questions, and prove the value before the money is spent.</p>
      <div data-reveal style="opacity:1; transform:translateY(18px); transition:transform .7s cubic-bezier(.2,.7,.2,1); display:flex; flex-wrap:wrap; align-items:center; gap:14px;">
        <a class="btn-primary" href="/company/contact?type=quote" style="display:inline-flex; align-items:center; gap:10px; text-decoration:none; color:#FFFFFF; font-weight:700; font-size:16px; padding:15px 28px; border-radius:44px;">
          Request a quote
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg>
        </a>
        <a class="btn-outline" href="/company/contact?type=consult" style="display:inline-flex; align-items:center; text-decoration:none; background:transparent; color:#ECEEF6; font-weight:600; font-size:16px; padding:15px 26px; border-radius:44px; border:1.5px solid rgba(255,255,255,0.18);">Book a free consult</a>
        <a class="flink" href="/company/work" style="display:inline-flex; align-items:center; gap:7px; text-decoration:none; color:#A7AABB; font-weight:600; font-size:15px;">See case studies
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg>
        </a>
      </div>
    </div>

    <div style="flex:1 1 360px; min-width:280px; position:relative; z-index:1; display:flex; justify-content:center;">
      <div class="fx-hud" style="position:relative; width:min(440px,88vw);">
        <span class="fx-corner tl"></span><span class="fx-corner tr"></span><span class="fx-corner bl"></span><span class="fx-corner br"></span>
        <div data-reveal style="opacity:1; transform:translateY(18px); transition:transform .8s cubic-bezier(.2,.7,.2,1); position:relative; border-radius:24px; overflow:hidden; aspect-ratio:4/3; background:linear-gradient(160deg,rgba(8,145,178,0.16),rgba(30,90,168,0.10)); border:1px solid rgba(34,211,238,0.35); box-shadow:0 30px 70px rgba(0,0,0,0.55), 0 0 50px rgba(8,145,178,0.18); padding:26px;">
          <div class="fx-scan"></div>
          <!-- abstract twin diagram -->
          <div style="font-family:'Space Mono',monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:#22D3EE; margin-bottom:18px;">Decision twin · live</div>
          <div style="display:flex; flex-direction:column; gap:10px;">
            <div style="display:flex; align-items:center; gap:10px;"><span style="font-family:'Space Mono',monospace; font-size:11px; color:#6B7080; width:64px;">DATA</span><div style="flex:1; height:8px; border-radius:6px; background:linear-gradient(90deg,rgba(34,211,238,0.5),rgba(34,211,238,0.06));"></div></div>
            <div style="display:flex; align-items:center; gap:10px;"><span style="font-family:'Space Mono',monospace; font-size:11px; color:#6B7080; width:64px;">ML</span><div style="flex:1; height:8px; border-radius:6px; background:linear-gradient(90deg,rgba(30,90,168,0.7),rgba(30,90,168,0.08));"></div></div>
            <div style="display:flex; align-items:center; gap:10px;"><span style="font-family:'Space Mono',monospace; font-size:11px; color:#6B7080; width:64px;">SIM</span><div style="flex:1; height:8px; border-radius:6px; background:linear-gradient(90deg,rgba(34,211,238,0.7),rgba(34,211,238,0.08));"></div></div>
            <div style="display:flex; align-items:center; gap:10px;"><span style="font-family:'Space Mono',monospace; font-size:11px; color:#6B7080; width:64px;">TWIN</span><div style="flex:1; height:8px; border-radius:6px; background:linear-gradient(90deg,rgba(34,211,238,0.9),rgba(30,90,168,0.3));"></div></div>
          </div>
          <div style="margin-top:22px; padding-top:18px; border-top:1px solid rgba(255,255,255,0.08); display:flex; justify-content:space-between; align-items:flex-end;">
            <div><div style="font-family:'Sora',sans-serif; font-weight:800; font-size:30px; color:#ECEEF6; line-height:1;">+£1.4M</div><div style="font-size:12px; color:#A7AABB; margin-top:4px;">proven annual value</div></div>
            <div style="font-family:'Space Mono',monospace; font-size:11px; color:#22D3EE;">baseline → policy</div>
          </div>
        </div>
        <div data-reveal style="opacity:1; transform:translateY(12px); transition:transform .6s ease; position:absolute; bottom:-18px; right:-12px; background:linear-gradient(120deg,#0891B2,#1E5AA8); color:#FFFFFF; border-radius:16px; padding:14px 18px; box-shadow:0 16px 34px rgba(8,145,178,0.4);">
          <div style="font-family:'Sora',sans-serif; font-weight:800; font-size:24px; line-height:1;">15</div>
          <div style="font-size:12px; font-weight:600; margin-top:3px;">delivered case studies</div>
        </div>
      </div>
    </div>
  </section>

  <!-- INDUSTRY MARQUEE -->
  <div style="border-top:1px solid rgba(34,211,238,0.12); border-bottom:1px solid rgba(34,211,238,0.12); padding:18px 0; overflow:hidden; background:rgba(255,255,255,0.015);">
    <div style="display:flex; width:max-content; animation:marquee 32s linear infinite; font-family:'Space Mono',monospace; font-size:14px; letter-spacing:0.12em; text-transform:uppercase; color:#A7AABB;">
      <span style="display:flex; gap:34px; padding-right:34px;">{sectors.map((s) => (<><span>{s}</span><span style="color:#22D3EE;">◆</span></>))}</span>
      <span style="display:flex; gap:34px; padding-right:34px;" aria-hidden="true">{sectors.map((s) => (<><span>{s}</span><span style="color:#22D3EE;">◆</span></>))}</span>
    </div>
  </div>

  <!-- SERVICES -->
  <section data-reveal style="max-width:1240px; margin:0 auto; padding:clamp(56px,8vw,104px) clamp(20px,5vw,56px); opacity:1; transform:translateY(26px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <div style="font-family:'Space Mono',monospace; font-size:13px; letter-spacing:0.18em; text-transform:uppercase; color:#22D3EE; margin-bottom:14px;">// What we do</div>
    <h2 data-split style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(28px,4.2vw,52px); line-height:1.08; letter-spacing:-0.025em; margin:0 0 18px; max-width:760px; color:#ECEEF6;">Four capabilities, one measured engine.</h2>
    <p style="font-size:17.5px; line-height:1.7; color:#A7AABB; max-width:680px; margin:0 0 48px;">Each service stands alone or plugs into the same decision twin — a simulation for the answer, a learning layer for the policy, and a baseline test so the value is never just a claim.</p>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(min(280px,100%),1fr)); gap:18px;">
      {services.map((s) => (
        <div class="scard" style="border-radius:22px; padding:32px 28px;">
          <div style="width:52px; height:52px; border-radius:14px; background:linear-gradient(150deg,rgba(8,145,178,0.22),rgba(30,90,168,0.18)); border:1px solid rgba(34,211,238,0.3); display:flex; align-items:center; justify-content:center; margin-bottom:20px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#22D3EE" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon}></svg>
          </div>
          <h3 style="font-family:'Sora',sans-serif; font-weight:700; font-size:21px; margin:0 0 12px; color:#ECEEF6; line-height:1.25;">{s.name}</h3>
          <p style="font-size:15.5px; line-height:1.7; color:#A7AABB; margin:0;">{s.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- COUNTERS -->
  <section data-reveal style="position:relative; border-top:1px solid rgba(34,211,238,0.1); border-bottom:1px solid rgba(34,211,238,0.1); background:rgba(8,9,12,0.5); opacity:1; transform:translateY(26px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <div style="max-width:1240px; margin:0 auto; padding:clamp(48px,6vw,76px) clamp(20px,5vw,56px); display:grid; grid-template-columns:repeat(auto-fit,minmax(min(160px,100%),1fr)); gap:36px;">
      {stats.map((s, i) => (
        <div>
          <div style={`font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(42px,5vw,60px); line-height:1; ${i === 0 ? 'color:#22D3EE;' : 'color:#ECEEF6;'}`}><span data-count={s.n}>0</span>{s.suffix}</div>
          <div style="font-size:15px; color:#A7AABB; margin-top:8px;">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- PROCESS -->
  <section data-reveal style="max-width:1240px; margin:0 auto; padding:clamp(56px,8vw,104px) clamp(20px,5vw,56px); opacity:1; transform:translateY(26px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <div style="font-family:'Space Mono',monospace; font-size:13px; letter-spacing:0.18em; text-transform:uppercase; color:#22D3EE; margin-bottom:14px;">// How we work</div>
    <h2 data-split style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(28px,4.2vw,52px); line-height:1.08; letter-spacing:-0.025em; margin:0 0 48px; max-width:680px; color:#ECEEF6;">A small, fixed-scope path from question to proof.</h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(min(240px,100%),1fr)); gap:18px;">
      {process.map((p) => (
        <div class="mcard" style="border-radius:20px; padding:30px 26px;">
          <div style="font-family:'Space Mono',monospace; font-weight:700; font-size:20px; background:linear-gradient(120deg,#22D3EE,#1E5AA8); -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; margin-bottom:14px;">{p.n}</div>
          <h3 style="font-family:'Sora',sans-serif; font-weight:700; font-size:20px; margin:0 0 10px; color:#ECEEF6;">{p.title}</h3>
          <p style="font-size:15px; line-height:1.65; color:#A7AABB; margin:0;">{p.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section data-reveal style="max-width:1240px; margin:0 auto; padding:0 clamp(20px,5vw,56px) clamp(56px,8vw,104px); opacity:1; transform:translateY(26px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <div style="font-family:'Space Mono',monospace; font-size:13px; letter-spacing:0.18em; text-transform:uppercase; color:#22D3EE; margin-bottom:14px;">// In their words</div>
    <h2 data-split style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(26px,3.8vw,46px); line-height:1.1; letter-spacing:-0.025em; margin:0 0 40px; max-width:640px; color:#ECEEF6;">Outcomes the client could measure.</h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(min(300px,100%),1fr)); gap:18px;">
      {testimonials.map((t) => (
        <div class="scard" style="border-radius:22px; padding:30px 28px; display:flex; flex-direction:column;">
          <div style="display:flex; gap:3px; margin-bottom:16px;">
            {[0,1,2,3,4].map(() => (<svg width="16" height="16" viewBox="0 0 24 24" fill="#22D3EE"><path d="M12 2l3 6.5 7 .8-5.2 4.7 1.5 6.9L12 18l-6.3 3.5 1.5-6.9L2 9.3l7-.8z"></path></svg>))}
          </div>
          <p style="font-size:16px; line-height:1.7; color:#ECEEF6; margin:0 0 20px; font-weight:500;">&ldquo;{t.quote}&rdquo;</p>
          <div style="margin-top:auto;">
            <div style="font-family:'Sora',sans-serif; font-weight:700; font-size:15px; color:#ECEEF6;">{t.who}</div>
            <div style="font-family:'Space Mono',monospace; font-size:12px; color:#6B7080; margin-top:3px;">{t.sector}</div>
          </div>
        </div>
      ))}
    </div>
    <p style="font-size:13px; color:#6B7080; margin:18px 0 0; font-family:'Space Mono',monospace;">* Quotes anonymized at the client's request; outcomes are real.</p>
  </section>

  <!-- CTA -->
  <section data-reveal style="max-width:1240px; margin:0 auto; padding:0 clamp(20px,5vw,56px) clamp(56px,8vw,104px); opacity:1; transform:translateY(26px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <div style="background:linear-gradient(120deg,#0891B2,#1E5AA8); border-radius:30px; padding:clamp(36px,6vw,72px); color:#FFFFFF; position:relative; overflow:hidden;">
      <div style="position:absolute; top:-80px; right:-40px; width:300px; height:300px; border-radius:50%; background:rgba(255,255,255,0.14); animation:blobB 16s ease-in-out infinite;"></div>
      <div style="position:relative; max-width:640px;">
        <h2 style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(28px,4.2vw,48px); line-height:1.08; letter-spacing:-0.025em; margin:0 0 16px;">Get a quote for your first decision twin.</h2>
        <p style="font-size:17.5px; line-height:1.6; margin:0 0 30px; color:rgba(255,255,255,0.85);">Tell us the decision you're about to make. We'll scope a small, fixed-price pilot on your own data and send a quote with a clear, numbers-backed deliverable.</p>
        <div style="display:flex; flex-wrap:wrap; gap:14px;">
          <a class="ctabtn" href="/company/contact?type=quote" style="display:inline-flex; align-items:center; gap:10px; text-decoration:none; background:#060606; color:#ECEEF6; font-weight:700; font-size:16px; padding:15px 28px; border-radius:44px;">Request a quote
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg>
          </a>
          <a class="btn-ghost" href="/company/contact?type=consult" style="display:inline-flex; align-items:center; text-decoration:none; background:rgba(255,255,255,0.1); color:#FFFFFF; font-weight:600; font-size:16px; padding:15px 26px; border-radius:44px; border:1.5px solid rgba(255,255,255,0.3);">Book a free consult</a>
          <a class="flink" href="/company/process" style="display:inline-flex; align-items:center; gap:7px; text-decoration:none; color:rgba(255,255,255,0.85); font-weight:600; font-size:15px;">See how it works
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</CompanyLayout>
