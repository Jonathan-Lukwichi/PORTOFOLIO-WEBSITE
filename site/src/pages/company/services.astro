---
import CompanyLayout from '../../layouts/CompanyLayout.astro';

const services = [
  {
    name: 'Simulation & digital twins',
    tag: 'The model',
    desc: 'A living model of your operation — discrete-event, agent-based or system-dynamics, or the hybrid between them — that keeps the surges, queues and breakdowns intact so a what-if is safe to test.',
    includes: ['Discrete-event, agent-based & system-dynamics models', 'Live digital twin connected to your data feed', 'Risk-free what-if and scenario sandboxes', '3D / visual environments where they help'],
    deliverable: 'A calibrated model that mirrors your operation and answers “what happens if…”.',
    icon: '<path d="M12 2v4M12 18v4M2 12h4M18 12h4M5 5l2.5 2.5M16.5 16.5L19 19M19 5l-2.5 2.5M7.5 16.5L5 19"></path><circle cx="12" cy="12" r="3.5"></circle>',
  },
  {
    name: 'Forecasting & machine learning',
    tag: 'The learning layer',
    desc: 'The prediction layer that drives the policy a model runs under — and every model is measured against a no-learning baseline, so the value of the prediction is proven, not assumed.',
    includes: ['Time-series demand & load forecasting', 'Survival, classification & anomaly models', 'Optimisation & metaheuristics', 'Baseline-versus-learning value tests'],
    deliverable: 'A measured uplift number: what the learning layer is worth versus doing nothing.',
    icon: '<path d="M3 17l5-5 4 3 6-7"></path><path d="M16 8h4v4"></path><path d="M3 21h18"></path>',
  },
  {
    name: 'Supply-chain & operations',
    tag: 'The system',
    desc: 'Whole-system optimisation across inventory, dispatch and network — find the configuration that minimises cost and lateness across the operation, not just one node in it.',
    includes: ['Multi-echelon inventory & reorder policy', 'Dispatch, routing & fleet sizing', 'Network design & capacity planning', 'Bullwhip & variability control'],
    deliverable: 'A policy and configuration with the cost and service-level numbers behind it.',
    icon: '<rect x="3" y="8" width="7" height="7" rx="1.2"></rect><rect x="14" y="4" width="7" height="7" rx="1.2"></rect><rect x="14" y="14" width="7" height="6" rx="1.2"></rect><path d="M10 11h4M17.5 11v3"></path>',
  },
  {
    name: 'Decision tooling & dashboards',
    tag: 'The delivery',
    desc: 'The pipelines and apps that put the model in front of the people who decide — clean inputs in, a clear recommendation with the numbers behind it out, kept calibrated as things change.',
    includes: ['Data pipelines from spreadsheet / ERP / sensors', 'Decision-support apps & dashboards', 'Scenario comparison tooling', 'Ongoing calibration & monitoring'],
    deliverable: 'A tool your team uses to make the call — not a report that sits in a drawer.',
    icon: '<rect x="3" y="4" width="18" height="14" rx="2"></rect><path d="M3 9h18M8 13h3M14 13h2M8 18v3M16 18v3M6 21h12"></path>',
  },
];
---
<CompanyLayout title="Services — JLW Analytics" active="services">
  <!-- HEADER -->
  <section data-reveal style="max-width:1240px; margin:0 auto; padding:clamp(40px,6vw,80px) clamp(20px,5vw,56px) clamp(20px,3vw,32px); opacity:1; transform:translateY(20px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <div style="font-family:'Space Mono',monospace; font-size:13px; letter-spacing:0.18em; text-transform:uppercase; color:#22D3EE; margin-bottom:16px;">// Services</div>
    <h1 data-split style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(34px,5vw,62px); line-height:1.05; letter-spacing:-0.03em; margin:0 0 18px; max-width:840px; color:#ECEEF6;">Four capabilities that combine into one measured engine.</h1>
    <p style="font-size:17.5px; line-height:1.7; color:#A7AABB; max-width:720px; margin:0;">Engage any service on its own, or stack them into a full decision twin. Whatever the scope, the deliverable is the same shape: a clear recommendation with the money value proven against a baseline.</p>
  </section>

  <!-- SERVICES -->
  <section style="max-width:1240px; margin:0 auto; padding:clamp(24px,4vw,40px) clamp(20px,5vw,56px) clamp(40px,6vw,72px);">
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(min(420px,100%),1fr)); gap:18px;">
      {services.map((s) => (
        <div class="scard" data-reveal style="opacity:1; transform:translateY(24px); transition:transform .7s cubic-bezier(.2,.7,.2,1), border-color .3s, box-shadow .3s; border-radius:24px; padding:34px 32px; display:flex; flex-direction:column;">
          <div style="display:flex; align-items:center; gap:16px; margin-bottom:20px;">
            <div style="width:54px; height:54px; border-radius:14px; background:linear-gradient(150deg,rgba(8,145,178,0.22),rgba(30,90,168,0.18)); border:1px solid rgba(34,211,238,0.3); display:flex; align-items:center; justify-content:center; flex:0 0 auto;">
              <svg width="25" height="25" viewBox="0 0 24 24" fill="none" stroke="#22D3EE" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon}></svg>
            </div>
            <div>
              <div style="font-family:'Space Mono',monospace; font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:#6B7080; margin-bottom:4px;">{s.tag}</div>
              <h2 style="font-family:'Sora',sans-serif; font-weight:700; font-size:22px; margin:0; color:#ECEEF6; line-height:1.2;">{s.name}</h2>
            </div>
          </div>
          <p style="font-size:15.5px; line-height:1.7; color:#A7AABB; margin:0 0 20px;">{s.desc}</p>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px 18px; margin-bottom:22px;">
            {s.includes.map((it) => (
              <div style="display:flex; align-items:flex-start; gap:9px; font-size:14px; color:#C4CDE8; line-height:1.4;">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#22D3EE" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" style="flex:0 0 auto; margin-top:2px;"><path d="M20 6L9 17l-5-5"></path></svg>
                <span>{it}</span>
              </div>
            ))}
          </div>
          <div style="margin-top:auto; background:rgba(8,145,178,0.08); border:1px solid rgba(34,211,238,0.18); border-radius:12px; padding:14px 16px;">
            <div style="font-family:'Space Mono',monospace; font-size:10px; letter-spacing:0.12em; text-transform:uppercase; color:#22D3EE; margin-bottom:4px;">You get</div>
            <div style="font-size:14.5px; font-weight:600; line-height:1.45; color:#ECEEF6;">{s.deliverable}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section data-reveal style="max-width:1240px; margin:0 auto; padding:0 clamp(20px,5vw,56px) clamp(56px,8vw,104px); opacity:1; transform:translateY(26px); transition:transform .8s cubic-bezier(.2,.7,.2,1);">
    <div style="background:linear-gradient(120deg,#0891B2,#1E5AA8); border-radius:28px; padding:clamp(34px,5vw,60px); color:#FFFFFF; text-align:center;">
      <h2 style="font-family:'Sora',sans-serif; font-weight:800; font-size:clamp(26px,3.6vw,42px); line-height:1.1; letter-spacing:-0.025em; margin:0 auto 14px; max-width:620px;">Not sure which you need? Start with the decision.</h2>
      <p style="font-size:17px; line-height:1.6; margin:0 auto 28px; max-width:560px; color:rgba(255,255,255,0.85);">Tell us the call you're about to make. We'll recommend the smallest scope that proves it and send a quote.</p>
      <div style="display:flex; flex-wrap:wrap; gap:14px; justify-content:center;">
        <a class="ctabtn" href="/company/contact?type=quote" style="display:inline-flex; align-items:center; gap:10px; text-decoration:none; background:#060606; color:#ECEEF6; font-weight:700; font-size:16px; padding:15px 30px; border-radius:44px;">Request a quote
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg>
        </a>
        <a class="btn-ghost" href="/company/contact?type=consult" style="display:inline-flex; align-items:center; text-decoration:none; background:rgba(255,255,255,0.12); color:#FFFFFF; font-weight:600; font-size:16px; padding:15px 28px; border-radius:44px; border:1.5px solid rgba(255,255,255,0.35);">Book a free consult</a>
      </div>
    </div>
  </section>
</CompanyLayout>
