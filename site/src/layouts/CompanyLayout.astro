---
import '../styles/global.css';
import CompanyNav from '../components/CompanyNav.astro';
import CompanyFooter from '../components/CompanyFooter.astro';

interface Props {
  title: string;
  description?: string;
  active?: 'home' | 'services' | 'process' | 'work' | 'contact';
}
const {
  title,
  description = 'JLW Analytics — decision twins for operations. Simulation and machine learning that prove the value of a change before the money is spent.',
  active = 'home',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Manrope:wght@400;500;600;700&family=Space+Mono:wght@400;700&family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Global futuristic backdrop -->
  <div class="fx-bg" aria-hidden="true"></div>
  <div class="fx-shell" style="background:transparent; min-height:100vh; font-family:'Sora',sans-serif; color:#ECEEF6; overflow-x:hidden; padding-top:64px;">
    <CompanyNav active={active} />
    <slot />
    <CompanyFooter />
  </div>
  <script is:inline src="/reveal.js"></script>
  <script is:inline src="/fx.js"></script>
  <script is:inline>
    window.addEventListener('load', function () {
      if (window.__jlwReveal) window.__jlwReveal(document);
    });
  </script>
</body>
</html>
